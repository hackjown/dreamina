# Dreamina backend base URL
VITE_API_BASE_URL=http://localhost:8000
# Default Dreamina sessionid (optional, can be set in UI)
VITE_DEFAULT_SESSION_ID=
# Express server port
PORT=3001

# ==================== 邮件服务 (SMTP) ====================
# 配置后，注册时发送验证码会通过邮件发送给用户
# 常见示例：
# - QQ 邮箱：SMTP_HOST=smtp.qq.com  SMTP_PORT=465  SMTP_SECURE=true
# - 163 邮箱：SMTP_HOST=smtp.163.com SMTP_PORT=465  SMTP_SECURE=true
# - Gmail:     SMTP_HOST=smtp.gmail.com SMTP_PORT=587  SMTP_SECURE=false

# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your_email@qq.com
# SMTP_PASS=your_smtp_authorization_code
# SMTP_FROM=your_email@qq.com
# SMTP_FROM_NAME=Dreamina Web
# SMTP_TLS_REJECT_UNAUTHORIZED=true

# 注意：也可以通过管理后台 -> 系统设置 来配置 SMTP 参数（推荐方式）
